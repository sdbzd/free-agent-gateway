# free-agent-gateway Configuration
# ================================

# Server settings
server:
  host: "127.0.0.1"
  port: 9000
  # Log level: error, warn, info, debug
  log_level: "info"
  # Request timeout in seconds
  request_timeout: 120
  # SSE keep-alive interval in seconds
  sse_keepalive: 15

# Routing strategy: round_robin, random, least_failed, least_rate, priority
routing:
  strategy: "least_failed"
  # Consecutive failure threshold before cooldown
  fail_threshold: 3
  # Key cooldown duration in seconds
  cooldown_seconds: 600
  # Auto-discover models from providers
  auto_discover: true

# Optional local context compression for large tool/log outputs.
# This never compresses normal user messages; it only rewrites large role=tool
# content before sending the request upstream.
context_compression:
  enabled: false
  command: "G:\\ai\\AgentsTools\\rtk.exe"
  min_message_tokens: 2000
  timeout_seconds: 3

# Provider fallback order
fallback:
- "cerebras"
- "github"
- "nvidia"
- "opencode"
- "openrouter"
- "groq"
- "huggingface"
- "ollama"

# Model aliases for agents
agents:
  hermes:
    default_model: "coding"
  openclaw:
    default_model: "chat"
  zeroclaw:
    default_model: "chat"
  document:
    default_model: "local"
  coding_agent:
    default_model: "coding"
  mcp_agent:
    default_model: "chat"

# Model alias definitions
models:
  coding:
    provider: "github"
    model: "openai/gpt-4.1-mini"
  chat:
    provider: "nvidia"
    model: "meta/llama-3.1-70b-instruct"
  local:
    provider: "ollama"
    model: "qwen2.5:7b"
  reasoning:
    provider: "github"
    model: "openai/o3-mini"
  fast:
    provider: "cerebras"
    model: "llama3.1-8b"
  embedding:
    provider: "nvidia"
    model: "nvidia/nv-embedqa-e5-v5"

# Provider configurations
providers:

  cerebras:
    type: "openai_compatible"
    enabled: false
    base_url: "https://api.cerebras.ai/v1"
    keys:
      - value: "${CEREBRAS_API_KEY}"
        tier: free
        # Set these if your Cerebras account publishes per-key quotas.
        # rpm_limit: 30
        # rpd_limit: 1000
    timeout_seconds: 30

  openrouter:
    type: "openai_compatible"
    enabled: false
    base_url: "https://openrouter.ai/api/v1"
    # Keys rotate automatically on failure
    keys:
      - value: "<YOUR_API_KEY>"
        tier: free
        # Optional advanced quotas. Leave these unset if the provider does not
        # publish per-key limits; routing.strategy: least_rate will still use
        # observed request volume and failures to spread load.
        # rpm_limit: 20
        # rpd_limit: 200
        # tpm_limit: 20000
        # tpd_limit: 200000
      # If any provider key is topped up but you still want it in the normal
      # free-model pool, keep tier: free and set its higher quota if known.
      # Use tier: paid only for last-resort paid escalation.
      # - value: "<TOPPED_UP_PROVIDER_KEY>"
      #   tier: free
      #   rpm_limit: 60
      #   rpd_limit: 1000
      - value: "<YOUR_API_KEY>"
        tier: free
      - value: "<YOUR_API_KEY>"
        tier: free
      - value: "<YOUR_API_KEY>"
        tier: free
      - value: "<YOUR_API_KEY>"
        tier: free

    # Health check settings
    health_check_model: "openai/gpt-4.1-mini"
    timeout_seconds: 30

  github:
    type: "github_models"
    enabled: false
    base_url: "https://models.inference.ai.azure.com"
    # Keys rotate automatically on failure
    keys:
      - "${GITHUB_TOKEN_1}"
      - "${GITHUB_TOKEN_2}"
      - "${GITHUB_TOKEN_3}"
    # Health check settings
    #health_check_model: "openai/gpt-4.1-mini"
    timeout_seconds: 30

  nvidia:
    type: "openai_compatible"
    enabled: false
    base_url: "https://integrate.api.nvidia.com/v1"
    keys:
      - value: "<YOUR_API_KEY>"
        tier: free
      - value: "<YOUR_API_KEY>"
        tier: free
      - value: "<YOUR_API_KEY>"
        tier: free
    health_check_model: "meta/llama-3.1-70b-instruct"
    timeout_seconds: 30

  opencode:
    type: "openai_compatible"
    enabled: false
    base_url: "https://opencode.ai/zen/v1"
    keys:
      - value: "${OPENCODE_API_KEY_1}"
        tier: free
      - value: "${OPENCODE_API_KEY_2}"
        tier: free
    health_check_model: "gpt-4o-mini"
    timeout_seconds: 30

  groq:
    type: "openai_compatible"
    enabled: false
    base_url: "https://api.groq.com/openai/v1"
    # Optional explicit proxy for providers blocked by local network/region.
    # If unset, reqwest still honors process-level HTTP_PROXY/HTTPS_PROXY/ALL_PROXY.
    # proxy_url: "http://127.0.0.1:7890"
    keys:
      - value: "${GROQ_API_KEY_1}"
        tier: free
      - value: "${GROQ_API_KEY_2}"
        tier: free
    timeout_seconds: 30

  huggingface:
    type: "huggingface"
    enabled: false
    base_url: "https://router.huggingface.co/v1"
    keys:
      - value: "${HF_TOKEN}"
        tier: free
    # Optional: set to a known HF router model after Refresh Models has
    # confirmed it for your key. Otherwise Test/Validate uses discovered inventory.
    health_check_model: ""
    timeout_seconds: 30

  ollama:
    type: "ollama"
    enabled: false
    # Ollama typically runs locally without auth
    base_url: "http://localhost:11434"
    keys:
      - "ollama"
    health_check_model: "qwen2.5:7b"
    timeout_seconds: 120
    # Ollama is the ultimate fallback
    priority: 100

# Adaptive routing settings (opt-in; existing /v1 behavior is unchanged)
adaptive_routing:
  enabled: false
  # observe = log decisions only; assist = override hard mismatches; auto = score-driven selection
  mode: "observe"
  allow_paid: false
  candidate_limit: 20
  learning_window_days: 7
  hard_override_on_capability_mismatch: true
  auto_models:
    coding-auto:
      task: "coding"
    document-auto:
      task: "document"
    vision-auto:
      task: "vision"
  agent_profiles:
    coding_agent:
      default_auto_model: "coding-auto"
      preferred_tasks: ["coding", "tools", "reasoning"]
      provider_groups: ["coding"]
    document:
      default_auto_model: "document-auto"
      preferred_tasks: ["long_context", "document"]
      provider_groups: ["free-cloud"]
  routing_groups:
    free-cloud:
      providers: ["openrouter", "nvidia", "groq", "huggingface", "cloudflare"]
    coding:
      providers: ["openrouter", "nvidia"]

# Health watcher settings
watcher:
  enabled: true
  # Check interval in seconds
  interval_seconds: 600
  # Timeout for each health check
  check_timeout_seconds: 10

# State persistence
state:
  # Auto-save interval in seconds
  save_interval_seconds: 30
  # File paths (relative to executable)
  state_file: "state.json"
  models_cache_file: "models.cache"

# CORS settings
cors:
  allowed_origins:
    - "*"
  allowed_methods:
    - "GET"
    - "POST"
    - "OPTIONS"
  allowed_headers:
    - "Authorization"
    - "Content-Type"
    - "X-Request-Id"
    - "X-Agent-Name"
